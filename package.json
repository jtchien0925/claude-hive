{
  "name": "claude-hive",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source multi-session Claude Code monitor & manager",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "node packages/server/dist/index.js & cd apps/web && pnpm start",
    "launch": "./launch.sh",
    "postinstall": "cd node_modules/.pnpm/node-pty@1.1.0/node_modules/node-pty && npx node-gyp rebuild 2>/dev/null || true"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "node-pty", "sharp"]
  }
}
